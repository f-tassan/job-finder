# Copy to .env and fill in. Never commit .env.

# --- Postgres (used by the db service and the API) ---
POSTGRES_USER=jobfinder
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=jobfinder
# These default to the compose service names; only override for external DBs.
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Web / reverse proxy ---
# Real domain in production (Caddy gets automatic HTTPS). Use "localhost" for local.
DOMAIN=localhost
# Browser-facing API base. Requests are proxied by Caddy at /api.
PUBLIC_API_URL=/api

# --- Auth & first user (Phase 1) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FIRST_USER_EMAIL=admin@example.com
FIRST_USER_PASSWORD=change-me-admin
MAX_USERS=3
# Encrypts stored employer-portal logins (used to sign in and save drafts).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank, a key is derived from JWT_SECRET (fine for dev).
CREDENTIALS_KEY=Vsfwu6QWoWYZl0b0ULwwJIhi8Ulglt0K8J1ZbDcfEU4=

# --- Discovery / relevance (Phase 2) ---
MATCH_THRESHOLD=0.25
AUTO_TRACK_THRESHOLD=0.55
DISCOVERY_INTERVAL_MINUTES=360

# --- LinkedIn discovery hardening (avoid rate-limit / blocking) ---
# Comma-separated proxy URLs, rotated per request. Empty = direct connection.
# e.g. LINKEDIN_PROXIES=http://user:pass@host1:port,http://user:pass@host2:port
LINKEDIN_PROXIES=
LINKEDIN_MIN_DELAY=3.0      # min seconds between LinkedIn requests
LINKEDIN_MAX_DELAY=7.0      # max seconds between LinkedIn requests
LINKEDIN_MAX_REQUESTS=120   # hard cap on LinkedIn requests per discovery run
LINKEDIN_MAX_RETRIES=3      # retries on 429/999/403 (with exponential backoff)
LINKEDIN_BACKOFF_BASE=20.0  # base backoff seconds (multiplied by attempt)

# IMAP for the email_alerts connector (optional; connector is off unless set)
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# --- LLM provider (CV parsing + tailoring) ---
# auto = use OpenAI if OPENAI_API_KEY set, else Anthropic; or force openai/anthropic.
# With neither key, the app still works (deterministic CV assembly, local relevance).
# NOTE: these are pay-as-you-go API keys (console.anthropic.com / platform.openai.com),
# separate from any Claude Pro or ChatGPT Plus subscription.
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_TAILOR_MODEL=gpt-4o
OPENAI_PARSE_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# --- External services (later phases) ---
TELEGRAM_BOT_TOKEN=
